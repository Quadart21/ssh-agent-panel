APP_NAME=SSH Control Panel API
APP_DISPLAY_NAME=SSH Control Panel
API_V1_PREFIX=/api/v1
FRONTEND_ORIGIN=https://ssh.norenvpn.com
FRONTEND_ORIGINS=https://ssh.norenvpn.com
ALLOWED_HOSTS=ssh.norenvpn.com,localhost,127.0.0.1
DATABASE_URL=postgresql+psycopg://ssh_panel:change_me@127.0.0.1:5432/ssh_panel
SECRET_KEY=replace-with-a-random-64-char-secret
ACCESS_TOKEN_EXPIRE_MINUTES=720
ENCRYPTION_KEY=
ADMIN_EMAIL=admin@ssh.norenvpn.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=300
ALERT_REPEAT_MINUTES=180
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
SESSION_INACTIVITY_MINUTES=720
