[Unit]
Description=SSH Control Panel API
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/gui-ssh-manager/backend
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/gui-ssh-manager/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
